{
	"info": {
		"_postman_id": "7fa72605-cb41-477d-9447-1f48fa134d19",
		"name": "vps-powermix (Bridge GS-PVS) — GS Open API v2",
		"description": "Colección GS Payment Open API v2 + webhooks PVS. Envelope {code,msg,data}. Paths /order/*.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "GS API v2",
			"item": [
				{
					"name": "1. Create order POST /order/qr",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"const data = response.data || response;",
									"if (data.thirdOrderNo) {",
									"    pm.environment.set(\"thirdOrderNo\", data.thirdOrderNo);",
									"    pm.environment.set(\"orderNo\", pm.variables.get(\"orderNo\") || \"GS-ORDER-001\");",
									"    pm.environment.set(\"qrId\", \"qr-\" + data.thirdOrderNo);",
									"    console.log(\"env:\", { thirdOrderNo: data.thirdOrderNo, qrId: \"qr-\" + data.thirdOrderNo });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderNo\": \"GS-ORDER-001\",\n    \"objectId\": \"drink-001\",\n    \"subject\": \"Coca Cola 500ml\",\n    \"attach\": \"deviceNo=serial-abc-123&deviceId=gs-device-001\",\n    \"totalAmount\": \"150.00\",\n    \"notifyUrl\": \"https://gs.example/notify\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/order/qr",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["order", "qr"]
						},
						"description": "GS Open API v2 create. Response data: qrUrl, orderStatus \"1\", thirdOrderNo. Saves thirdOrderNo to env."
					},
					"response": []
				},
				{
					"name": "2. Query status POST /order/status",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderNo\": \"GS-ORDER-001\",\n    \"thirdOrderNo\": \"{{thirdOrderNo}}\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/order/status",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["order", "status"]
						},
						"description": "Pair orderNo + thirdOrderNo. orderStatus string 1-6."
					},
					"response": []
				},
				{
					"name": "3. Complete POST /order/complete",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderNo\": \"GS-ORDER-001\",\n    \"thirdOrderNo\": \"{{thirdOrderNo}}\",\n    \"success\": true,\n    \"orderStatus\": 2,\n    \"outStockStatus\": 2,\n    \"outStockTime\": \"2026-07-10 12:00:00\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/order/complete",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["order", "complete"]
						},
						"description": "success+outStockStatus=2 → DONE. success=false → FAILED refundable."
					},
					"response": []
				},
				{
					"name": "4. Cancel POST /order/cancel",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderNo\": \"GS-ORDER-001\",\n    \"thirdOrderNo\": \"{{thirdOrderNo}}\",\n    \"orderStatus\": 0,\n    \"remark\": \"user cancel\",\n    \"cancelTime\": \"2026-07-10 12:00:00\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/order/cancel",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["order", "cancel"]
						},
						"description": "Cancel before/after pay when SM allows. Idempotent if already CANCELLED."
					},
					"response": []
				},
				{
					"name": "5. Refund POST /order/refund",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderNo\": \"GS-ORDER-001\",\n    \"thirdOrderNo\": \"{{thirdOrderNo}}\",\n    \"refundNo\": \"ref-{{thirdOrderNo}}\",\n    \"refundAmount\": \"150.00\",\n    \"refundReason\": \"Bebida trabada en la espiral\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/order/refund",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["order", "refund"]
						},
						"description": "PVS reverse async. Immediate refundStatus often \"waiting\"."
					},
					"response": []
				},
				{
					"name": "6. Refund status POST /order/refundStatus",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderNo\": \"GS-ORDER-001\",\n    \"thirdOrderNo\": \"{{thirdOrderNo}}\",\n    \"refundNo\": \"ref-{{thirdOrderNo}}\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/order/refundStatus",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["order", "refundStatus"]
						},
						"description": "Query refund: pending|success|fail."
					},
					"response": []
				}
			]
		},
		{
			"name": "PVS Webhooks Simulation",
			"item": [
				{
					"name": "1. Simular Pago Webhook (PVS -> Bridge)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"qrId\": \"{{qrId}}\",\n    \"stateId\": 5\n}"
						},
						"url": {
							"raw": "http://localhost:8080/webhook/pvs",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["webhook", "pvs"]
						},
						"description": "stateId 5 = Approved. Triggers PAYMENT_CONFIRMED + GS notify best-effort."
					},
					"response": []
				},
				{
					"name": "2. Simular Reverso Confirmado Webhook (PVS -> Bridge)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"qrId\": \"{{qrId}}\",\n    \"stateId\": 4\n}"
						},
						"url": {
							"raw": "http://localhost:8080/webhook/pvs",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["webhook", "pvs"]
						},
						"description": "stateId 4 = Reversed. Confirms refund → REFUNDED."
					},
					"response": []
				}
			]
		},
		{
			"name": "PVS Mock Admin Controls",
			"item": [
				{
					"name": "Forzar Estado en PVS (Simular reconciliación)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"stateId\": 5\n}"
						},
						"url": {
							"raw": "http://localhost:8081/admin/transactions/{{qrId}}/status",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8081",
							"path": ["admin", "transactions", "{{qrId}}", "status"]
						},
						"description": "Force PVS state for reconciler lost-webhook tests."
					},
					"response": []
				}
			]
		},
		{
			"name": "Diagnostics",
			"item": [
				{
					"name": "Healthcheck",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/healthz",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["healthz"]
						}
					},
					"response": []
				},
				{
					"name": "Prometheus Metrics",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/metrics",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["metrics"]
						}
					},
					"response": []
				}
			]
		}
	]
}
