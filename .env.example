# --- Servidor ---
HTTP_ADDR=:8080
LOG_LEVEL=debug
LOG_FORMAT=json

# --- Base de datos ---
# Reemplaza con tus credenciales locales de Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vps_powermix?sslmode=disable

# --- GS (Máquina Expendedora GSWYIT) ---
# Mocks locales ya que actuaremos como la máquina usando curl.
GS_BASE_URL=http://localhost:8082
GS_KEY=gs_mock_key
GS_SECRET=gs_mock_secret
GS_PVS_ENABLED=true

# --- PVS (Proveedor QR) ---
# Apuntamos al PVS mock local en el puerto 8081.
PVS_BASE_URL=http://localhost:8081
PVS_CLIENT_ID=pvs_mock_client
PVS_CLIENT_SECRET=pvs_mock_secret
PVS_CALLBACK_URL=http://localhost:8080/webhook/pvs

# --- Reconciler ---
RECONCILER_ENABLED=true
RECONCILER_INTERVAL_SEC=10
RECONCILER_BATCH_SIZE=200

# --- Keepalive (evita spin-down por inactividad) ---------------------------
# Render free tier duerme el servicio tras ~15 min sin trafico entrante.
# El proceso se auto-pingea su propia URL publica cada N segundos para
# mantenerlo despierto. IMPORTANTE: debe ser la URL PUBLICA (atraviesa el
# router de Render), no localhost.
#
# RENDER_EXTERNAL_URL la inyecta Render automaticamente (no hace falta
# setearla ahi). KEEPALIVE_URL tiene prioridad por si queres override o
# usas otra plataforma. Si ninguna queda seteada, el keepalive queda OFF.
#KEEPALIVE_URL=
# Intervalo en segundos. Render free duerme a los 15 min; 30s sobra.
KEEPALIVE_INTERVAL_SEC=30

# --- HTTP body logging (GS/PVS in/out) ------------------------------------
# Default true: loguea bodies sanitizados (secrets/QR truncados).
# LOG_HTTP_BODIES=false
# Max bytes del body ya sanitizado en el log (0 = 8192 default del codigo).
# LOG_HTTP_BODY_MAX_BYTES=8192
